{
  "uid": "automind-overview",
  "title": "АвтоMind Overview",
  "tags": ["automind", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Лидов всего",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM leads;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "В квалификации",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM leads WHERE status='qualifying';",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Закрыто (won)",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM leads WHERE status='won';",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Бронирования (всего)",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM bookings;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Эскалации (24h)",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM messages WHERE payload ? 'escalate' AND created_at >= NOW() - INTERVAL '24 hours';",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Конверсия в won",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE status='won') / NULLIF(COUNT(*),0), 1) AS value FROM leads;",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Новые лиды по дням (по нишам)",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, niche AS metric, COUNT(*) AS value FROM leads WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Бронирования по часам",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, COUNT(*) AS \"bookings\" FROM bookings WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 20,
      "type": "barchart",
      "title": "Воронка (статусы лидов)",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT status, COUNT(*) AS count FROM leads GROUP BY status ORDER BY CASE status WHEN 'new' THEN 1 WHEN 'contacted' THEN 2 WHEN 'qualifying' THEN 3 WHEN 'meeting' THEN 4 WHEN 'won' THEN 5 WHEN 'lost' THEN 6 ELSE 7 END;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 21,
      "type": "table",
      "title": "Топ ниш по количеству лидов",
      "datasource": {
        "type": "postgres",
        "uid": "automind-postgres-ro"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT niche, COUNT(*) AS leads, COUNT(*) FILTER (WHERE status='won') AS won, ROUND(100.0 * COUNT(*) FILTER (WHERE status='won') / NULLIF(COUNT(*),0), 1) AS conv_pct FROM leads GROUP BY niche ORDER BY leads DESC LIMIT 20;",
          "rawQuery": true
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    }
  ]
}
