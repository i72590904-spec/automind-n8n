# =============================================================================
# АвтоMind — пример переменных окружения
# Скопируй в .env и заполни значениями. .env НЕ коммитим в git.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (база n8n + рабочие данные ботов)
# -----------------------------------------------------------------------------
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

# Отдельная база/пользователь для прикладных таблиц (бронирования и т.д.)
APP_DB_NAME=automind
APP_DB_USER=automind
APP_DB_PASSWORD=change_me_app_password

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
# ОБЯЗАТЕЛЬНО сгенерируй случайный ключ (32+ байт) и НЕ меняй его потом —
# иначе все сохранённые credentials в n8n станут нечитаемы.
# Сгенерировать на Windows PowerShell:
#   [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
N8N_ENCRYPTION_KEY=replace_with_32byte_random_base64

# Базовая авторизация UI (логин/пароль для http://localhost:5678)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_admin_password

# Публичный URL для приёма Telegram-вебхуков. Заполняется ПОСЛЕ запуска
# Cloudflare Tunnel или ngrok. Пример: https://automind.your-domain.com
# Если используешь named tunnel cloudflared — это твой DNS-домен.
# Если quick tunnel (cloudflared tunnel --url ...) — это выданный *.trycloudflare.com.
WEBHOOK_URL=https://replace-with-your-public-url.example.com

# Часовой пояс (Europe/Moscow, Asia/Yekaterinburg и т.д.)
GENERIC_TIMEZONE=Europe/Moscow
TZ=Europe/Moscow

# -----------------------------------------------------------------------------
# Redis (кеш / очереди / state)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# -----------------------------------------------------------------------------
# Obsidian + Vault (Фазы 2-3)
# -----------------------------------------------------------------------------
# URL Local REST API плагина Obsidian. На Windows/Mac Docker Desktop
# host.docker.internal указывает на хост; на Linux нужно extra_hosts (уже есть).
OBSIDIAN_API_URL=http://host.docker.internal:27123

# Локальный путь к папке Vault на твоём диске (Windows). Монтируется в /vault
# внутри контейнера n8n, чтобы AI-агенты могли коммитить через workflow.
# Пример: OBSIDIAN_VAULT_PATH=C:\Users\Ivan\Documents\Vault
# Если не задан — будет смонтирован пустой ./vault-placeholder, чтобы compose не падал.
OBSIDIAN_VAULT_PATH=

# Удалённый репозиторий Vault на GitHub (HTTPS!), используется workflow 13.
# Пример: https://github.com/i72590904-spec/automind-vault.git
VAULT_REMOTE_URL=

# !!! ОПАСНО !!! GitHub PAT для пушей в Vault.
# НЕ КОММИТИТЬ. Лучше — храни этот ключ в credentials самого n8n (Generic Credential)
# и подменяй $env.GH_TOKEN_VAULT через workflow-инжект, либо передавай его через
# n8n credential injection в node Execute Command. В .env ниже — только если
# никаких других вариантов нет.
GH_TOKEN_VAULT=

# -----------------------------------------------------------------------------
# Секреты, которые подключаются ВНУТРИ n8n через Credentials UI
# (НЕ нужны в .env, перечислены только как чек-лист — что подготовить)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN     — от @BotFather
# TELEGRAM_BOT_USERNAME  — для удобства
# OPENAI_API_KEY         — https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY      — https://console.anthropic.com (если используешь Claude)
# OBSIDIAN_API_KEY       — generated в плагине Local REST API (хранить в n8n credential)

# -----------------------------------------------------------------------------
# Фаза 4: AI-агенты + парсер ВК + аутрич
# -----------------------------------------------------------------------------
# LLM-ключи живут в n8n credentials (через UI), а не в .env:
#   - "OpenRouter — АвтоMind" (OpenAI-совместимая, base URL https://openrouter.ai/api/v1)
#     → используется в workflow 20, 22 (Claude Sonnet 4.5)
#   - "OpenAI — embeddings" (стандартный base URL)
#     → используется только в workflow 23 (RAG sync, text-embedding-3-small)
# Получить ключи: https://openrouter.ai/keys и https://platform.openai.com/api-keys.

# Сервисный токен ВК API для groups.search в workflow 21.
# Получить: https://vk.com/apps?act=manage → твоё приложение → Settings → «Сервисный ключ».
VK_ACCESS_TOKEN=

# Telegram chat_id, куда AI шлёт алерты (эскалация диалогов, драфты outreach).
# Получить: GET https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id.
TEAM_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Фаза 6: Мониторинг (Loki + Grafana). Запуск: docker compose --profile monitoring up -d
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Пароль для роли automind_ro (read-only). Используется Grafana datasource'ом
# "Postgres (readonly)" и Analytics-агентом (workflow 33). Установи руками:
#   docker exec -it automind-postgres psql -U postgres -d automind \
#     -c "ALTER ROLE automind_ro WITH PASSWORD '<этот_пароль>'"
POSTGRES_RO_PASSWORD=
